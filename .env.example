PORT=3000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/app
JWT_SECRET=changeme
# Comma-separated list of allowed origins for CORS (no spaces)
CORS_ORIGINS=http://localhost:4200,http://localhost:3000,http://localhost:5173
# Set to true if you send cookies or use credentials in fetch/axios
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOWED_METHODS=GET,POST,PATCH,PUT,DELETE,OPTIONS
# Additional allowed headers; base includes Content-Type, Authorization, brand-id, outlet-id
CORS_ALLOWED_HEADERS=
CORS_EXPOSED_HEADERS=
#
# Index management (development convenience)
# When true, the server runs mongoose.syncIndexes() at startup
# Defaults to true in NODE_ENV!=production
SYNC_INDEXES=
